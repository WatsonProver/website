---
// Home page — SKELETON ONLY.
// Layout + palette are wired up; all text is placeholder. Real hero copy,
// feature descriptions, and positioning are for a later pass.
import Base from '../layouts/Base.astro';
import Button from '../components/Button.astro';

// Placeholder feature cards — titles/blurbs are stand-ins, not final copy.
const features = [
  { title: 'Feature one', body: 'Placeholder description for a key feature.' },
  { title: 'Feature two', body: 'Placeholder description for a key feature.' },
  { title: 'Feature three', body: 'Placeholder description for a key feature.' },
];
---

<Base title="Watson">
  <!-- HERO ---------------------------------------------------------------- -->
  <section class="hero">
    <div class="container hero-inner">
      <p class="eyebrow">Placeholder eyebrow</p>
      <h1>Headline placeholder</h1>
      <p class="lede">
        Subheading placeholder — a sentence or two describing Watson goes here
        later.
      </p>
      <div class="cta-row">
        <Button href="/about">Primary action</Button>
        <Button href="https://zfc.watson-prover.org" variant="outline" external>
          Read the textbook
        </Button>
      </div>
    </div>
  </section>

  <!-- FEATURE GRID -------------------------------------------------------- -->
  <section class="container features">
    <div class="feature-grid">
      {features.map((f) => (
        <article class="card">
          <span class="card-badge" aria-hidden="true"></span>
          <h3>{f.title}</h3>
          <p>{f.body}</p>
        </article>
      ))}
    </div>
  </section>
</Base>

<style>
  .hero {
    padding-block: 5rem 3.5rem;
    border-bottom: 1px solid var(--border);
  }
  .hero-inner {
    max-width: var(--prose-max);
  }
  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--accent);
    margin: 0 0 0.75rem;
  }
  .hero h1 {
    font-size: clamp(2.25rem, 5vw, 3.25rem);
    margin-bottom: 0.5rem;
  }
  .lede {
    font-size: 1.2rem;
    color: var(--muted);
    max-width: 40ch;
    margin-bottom: 1.75rem;
  }
  .cta-row {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .features {
    padding-block: 3.5rem;
  }
  .feature-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
  }
  .card {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
    background: var(--bg);
  }
  .card-badge {
    display: block;
    width: 32px;
    height: 32px;
    border-radius: 2px;
    background: var(--accent);
    margin-bottom: 1rem;
  }
  .card h3 {
    margin-bottom: 0.4rem;
  }
  .card p {
    color: var(--muted);
    margin: 0;
  }
</style>
